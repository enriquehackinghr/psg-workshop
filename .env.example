# Server
PORT=3001
NODE_ENV=development

# Claude (Anthropic) – answer generation
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Voyage AI – embeddings (pairs with Claude)
VOYAGE_API_KEY=pa-...

# Supabase (either naming convention works)
SUPABASE_URL=https://your-project.supabase.co
# or: NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin ingestion endpoint protection
ADMIN_API_KEY=change-me-to-a-secure-random-string

# CORS – comma-separated allowed origins for widget embeds
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Client (Vite) – prefix with VITE_
VITE_API_URL=http://localhost:3001
